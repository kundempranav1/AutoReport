# Copy this file to ".env" and fill in your values.

# ===== OpenAI =====
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-3.5-turbo

# ===== MySQL =====
# If MYSQL_USER is empty, the app falls back to a local SQLite DB
# (great for first-time setup).
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=autoreport_ai

# Optional explicit override (takes precedence over the fields above):
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/autoreport_ai?charset=utf8mb4

# ===== Flask =====
SECRET_KEY=autoreport-ai-dev-secret